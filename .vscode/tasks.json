{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Build LabelPrinterApp",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/std:c++17",
                "/DWIN32_LEAN_AND_MEAN",
                "/DNOMINMAX",
                "/I${workspaceFolder}\\include",
                "/Fe${workspaceFolder}\\LabelPrinterApp.exe",
                "${workspaceFolder}\\src\\main.cpp",
                "${workspaceFolder}\\src\\ZebraPrinter.cpp",
                "${workspaceFolder}\\src\\ui\\MainWindow.cpp",
                "${workspaceFolder}\\src\\ui\\PreviewWidget.cpp",
                "Gdi32.lib",
                "User32.lib",
                "Winspool.lib",
                "/link",
                "/SUBSYSTEM:WINDOWS"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}
