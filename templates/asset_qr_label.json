{
  "name": "QR Code Asset Label",
  "settings": {
    "printerName": "",
    "dpi": 203,
    "darkness": 15,
    "speedIps": 4,
    "copies": 1,
    "labelWidthInches": 2.25,
    "labelHeightInches": 0.75,
    "marginLeftInches": 0.0,
    "marginTopInches": 0.0,
    "gapInches": 0.125,
    "mediaSensing": "Gap",
    "orientation": "Portrait"
  },
  "elements": [
    {
      "id": "asset_title",
      "name": "Asset Title",
      "type": "Text",
      "source": "Fixed",
      "text": "ASSET {AssetId}",
      "xInches": 0.08,
      "yInches": 0.06,
      "boxWidthInches": 1.32,
      "fontHeightDots": 36,
      "fontWidthDots": 28,
      "fontName": "0",
      "bold": true,
      "autoFit": true,
      "alignment": "Left",
      "rotation": "0",
      "doNotPrint": false
    },
    {
      "id": "asset_desc",
      "name": "Asset Description",
      "type": "Text",
      "source": "Variable",
      "text": "{Description}",
      "variableName": "Description",
      "xInches": 0.08,
      "yInches": 0.28,
      "boxWidthInches": 1.28,
      "fontHeightDots": 22,
      "fontWidthDots": 18,
      "fontName": "0",
      "autoFit": true,
      "wrap": true,
      "multiLine": true,
      "maxLines": 2,
      "alignment": "Left",
      "rotation": "0",
      "doNotPrint": false
    },
    {
      "id": "asset_qr",
      "name": "Asset QR",
      "type": "QRCode",
      "source": "Fixed",
      "text": "ASSET:{AssetId}|SERIAL:{Serial}|DATE:{Date}",
      "xInches": 1.58,
      "yInches": 0.08,
      "qrModel": 2,
      "qrMagnification": 4,
      "rotation": "0",
      "doNotPrint": false
    }
  ]
}
